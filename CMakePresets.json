{
  "version": 8,
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "configurePresets": [
    {
      "name": "cpm-cache-default",
      "hidden": true,
      "cacheVariables": {
        "CPM_SOURCE_CACHE": "~/.cache/CPM"
      }
    },
    {
      "name": "common-config",
      "description": "common configuration",
      "hidden": true,
      "binaryDir": "${sourceDir}/__out/build/${presetName}",
      "cacheVariables": {},
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    },
    {
      "name": "windows-config",
      "hidden": true,
      "cacheVariables": {},
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-config",
      "hidden": true,
      "cacheVariables": {},
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "emscripten-config",
      "hidden": true,
      "cacheVariables": {}
    },
    {
      "name": "windows_default",
      "description": "Windows default configuration",
      "displayName": "Windows Default",
      "inherits": [
        "common-config",
        "cpm-cache-default",
        "windows-config"
      ],
      "cacheVariables": {}
    },
    {
      "name": "enscripten_default",
      "description": "Enscripten default configuration",
      "displayName": "Enscripten Default",
      "inherits": [
        "common-config",
        "cpm-cache-default",
        "emscripten-config"
      ],
      "cacheVariables": {}
    }
  ],
  "buildPresets": [
    {
      "name": "Windows Debug",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_default",
      "configuration": "Debug"
    },
    {
      "name": "Windows Release",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_default",
      "configuration": "Release"
    },
    {
      "name": "Enscripten Debug",
      "description": "",
      "displayName": "",
      "configurePreset": "enscripten_default",
      "configuration": "Debug"
    },
    {
      "name": "Enscripten Release",
      "description": "",
      "displayName": "",
      "configurePreset": "enscripten_default",
      "configuration": "Release"
    }
  ]
}