{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows_msvc",
      "displayName": "Windows MSVC",
      "binaryDir": "${sourceDir}/__out/build/${presetName}",
      "cacheVariables": {
        "CMAKE_GENERATOR": "Ninja Multi-Config",
        "CMAKE_VERBOSE_MAKEFILE": "ON",
        "CMAKE_MAKE_PROGRAM": "E:/Tools/ninja/ninja.exe",
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl",
        "CPM_SOURCE_CACHE": "E:/Cache/CPM"
      },
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "toolset": {
        "value": "host=x64",
        "strategy": "external"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "Debug MSVC",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_msvc",
      "configuration": "Debug"
    },
    {
      "name": "Release MSVC",
      "description": "",
      "displayName": "",
      "configurePreset": "windows_msvc",
      "configuration": "Release"
    }
  ]
}
